[run]
source = .
omit =
    */venv/*
    */.venv/*
    */migrations/*
    */tests/*
    */tests*.py
    manage.py
    manage_test.py
    */settings*.py
    */asgi.py
    */wsgi.py
    */__init__.py
    */management/commands/*
    */tasks.py
    */consumers.py
    */routing.py
    */storage_backends.py
    */pdf_generator.py
    */relatorio_pdf.py
    */texto_padrao.py

[report]
show_missing = True
skip_covered = True
fail_under = 0
